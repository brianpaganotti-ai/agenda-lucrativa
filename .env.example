# =============================================================================
# Agenda Lucrativa / NEXUS — Variáveis de Ambiente
# Copie para .env e preencha os valores reais. NUNCA commite o .env.
# =============================================================================

# --- Google Cloud ---
PROJECT_ID=project-87c1c65b-10d3-40d5-999
GOOGLE_APPLICATION_CREDENTIALS=/opt/nexus/.gcloud/agenda-lucrativa-key.json
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=           # obtido via @BotFather
TELEGRAM_ADMIN_CHAT_ID=       # seu chat ID pessoal (via @userinfobot)

# --- OpenCode / Gemini ---
OPENCODE_MODEL=google/gemini-2.0-flash-exp   # modelo Gemini via OpenCode
GEMINI_API_KEY=                               # Google AI Studio API key

# --- WhatsApp ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# --- Email ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# --- Serper (busca web) ---
SERPER_API_KEY=

# --- Firestore ---
FIRESTORE_COLLECTION=agenda

# --- Flask ---
SECRET_KEY=
FLASK_ENV=production
