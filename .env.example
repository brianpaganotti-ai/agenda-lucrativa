# =============================================================================
# Agenda Lucrativa — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no git.
# =============================================================================

# --- Google Cloud ---
PROJECT_ID=project-87c1c65b-10d3-40d5-999
GOOGLE_APPLICATION_CREDENTIALS=.gcloud/agenda-lucrativa-key.json
GCP_REGION=us-central1

# --- Firestore ---
# (usa GOOGLE_APPLICATION_CREDENTIALS automaticamente)
FIRESTORE_COLLECTION=agenda

# --- Cloud Run ---
CLOUD_RUN_SERVICE=agenda-lucrativa
IMAGE_URL=us-central1-docker.pkg.dev/project-87c1c65b-10d3-40d5-999/agenda-lucrativa-repo/agenda-lucrativa

# --- API Keys (também armazenadas no Secret Manager) ---
API_KEY=
SECRET_KEY=
SERPER_API_KEY=

# --- WhatsApp Integration ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# --- Email ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# --- Banco de dados (Cloud SQL — opcional) ---
DATABASE_URL=
CLOUD_SQL_CONNECTION_NAME=project-87c1c65b-10d3-40d5-999:us-central1:agenda-db
DB_USER=
DB_PASS=
DB_NAME=agenda
